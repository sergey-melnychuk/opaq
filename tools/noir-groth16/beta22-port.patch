diff --git a/crates/noir-acir/src/lib.rs b/crates/noir-acir/src/lib.rs
index c95c6b3..7ba3ae7 100644
--- a/crates/noir-acir/src/lib.rs
+++ b/crates/noir-acir/src/lib.rs
@@ -4,7 +4,101 @@ use acir::{
     circuit::{Circuit, Opcode, Program},
     FieldElement,
 };
+use acir::circuit::brillig::{BrilligInputs, BrilligOutputs};
+use acir::native_types::Witness;
 use base64::Engine;
+
+/// Maximum witness index referenced anywhere in `circuit`.
+///
+/// Replaces `Circuit::current_witness_index`, removed from acir in noir
+/// beta.22. Mirrors the witness-folding acvm itself uses (private/public/return
+/// parameters + every opcode), and is a safe upper bound for wire allocation:
+/// any witness referenced by a constraint is <= this value. For circuits emitted
+/// by nargo there are no gaps, so this equals the old field exactly.
+pub fn max_witness_index(circuit: &Circuit<FieldElement>) -> u32 {
+    fn upd(max: &mut u32, w: Witness) {
+        let i = w.witness_index();
+        if i > *max {
+            *max = i;
+        }
+    }
+    fn fold_expr(max: &mut u32, expr: &acir::native_types::Expression<FieldElement>) {
+        for t in &expr.mul_terms {
+            upd(max, t.1);
+            upd(max, t.2);
+        }
+        for t in &expr.linear_combinations {
+            upd(max, t.1);
+        }
+    }
+
+    let mut max = 0u32;
+    for w in &circuit.private_parameters {
+        upd(&mut max, *w);
+    }
+    for w in &circuit.public_parameters.0 {
+        upd(&mut max, *w);
+    }
+    for w in &circuit.return_values.0 {
+        upd(&mut max, *w);
+    }
+    for opcode in &circuit.opcodes {
+        match opcode {
+            Opcode::AssertZero(expr) => fold_expr(&mut max, expr),
+            Opcode::BlackBoxFuncCall(call) => {
+                for w in call.get_input_witnesses() {
+                    upd(&mut max, w);
+                }
+                for w in call.get_outputs_vec() {
+                    upd(&mut max, w);
+                }
+            }
+            Opcode::MemoryOp { op, .. } => {
+                upd(&mut max, op.index);
+                upd(&mut max, op.value);
+            }
+            Opcode::MemoryInit { init, .. } => {
+                for w in init {
+                    upd(&mut max, *w);
+                }
+            }
+            Opcode::BrilligCall { inputs, outputs, predicate, .. } => {
+                fold_expr(&mut max, predicate);
+                for inp in inputs {
+                    match inp {
+                        BrilligInputs::Single(e) => fold_expr(&mut max, e),
+                        BrilligInputs::Array(es) => {
+                            for e in es {
+                                fold_expr(&mut max, e);
+                            }
+                        }
+                        BrilligInputs::MemoryArray(_) => {}
+                    }
+                }
+                for out in outputs {
+                    match out {
+                        BrilligOutputs::Simple(w) => upd(&mut max, *w),
+                        BrilligOutputs::Array(ws) => {
+                            for w in ws {
+                                upd(&mut max, *w);
+                            }
+                        }
+                    }
+                }
+            }
+            Opcode::Call { inputs, outputs, predicate, .. } => {
+                fold_expr(&mut max, predicate);
+                for w in inputs {
+                    upd(&mut max, *w);
+                }
+                for w in outputs {
+                    upd(&mut max, *w);
+                }
+            }
+        }
+    }
+    max
+}
